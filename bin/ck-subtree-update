#!/usr/bin/env bash
#
# ck-subtree-update — Split projects/composablekernel/ from rocm-libraries
# into a standalone branch that can be used as a CK remote.
#
# Usage:
#   cd /path/to/rocm-libraries
#   ck-subtree-update [--rejoin] [source-branch]
#
# This creates/updates a branch named "ck-split/<source-branch>" where
# projects/composablekernel/ is the root. The resulting branch is compatible
# with the standalone CK repo and can be fetched by customer repos.
#
# Options:
#   --rejoin  Record the split point as a merge commit on the source branch
#             so future splits are incremental. Without this, the source
#             branch is not modified.
#
# Examples:
#   ck-subtree-update                    # split current branch
#   ck-subtree-update develop            # split develop
#   ck-subtree-update --rejoin develop   # split develop (incremental)

set -euo pipefail

CK_PREFIX="projects/composablekernel"

REJOIN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            echo "Usage: ck-subtree-update [--rejoin] [source-branch]"
            echo ""
            echo "Split projects/composablekernel/ from rocm-libraries into a"
            echo "standalone branch 'ck-split/<source-branch>' that can be used"
            echo "as a CK remote in customer repos."
            echo ""
            echo "Options:"
            echo "  --rejoin  Record split point as a merge commit on the source"
            echo "            branch so future splits are incremental (faster)."
            echo "            Without this flag, the source branch is not modified."
            echo ""
            echo "Run this from the root of rocm-libraries."
            echo ""
            echo "Examples:"
            echo "  ck-subtree-update                    # split current branch"
            echo "  ck-subtree-update develop            # split develop"
            echo "  ck-subtree-update --rejoin develop   # split develop (incremental)"
            exit 0
            ;;
        --rejoin)
            REJOIN=true
            shift
            ;;
        *)
            SOURCE_BRANCH="$1"
            shift
            ;;
    esac
done

# Determine the source branch (default: current branch)
if [[ -z "${SOURCE_BRANCH:-}" ]]; then
    SOURCE_BRANCH=$(git rev-parse --abbrev-ref HEAD)
fi

SPLIT_BRANCH="ck-split/${SOURCE_BRANCH}"

echo "==> Splitting '${CK_PREFIX}' from '${SOURCE_BRANCH}'"
echo "    into branch '${SPLIT_BRANCH}'"
echo ""

# Ensure we're in a git repo that has the CK prefix
if [[ ! -d "${CK_PREFIX}" ]]; then
    echo "ERROR: '${CK_PREFIX}' not found."
    echo "       Run this from the root of rocm-libraries."
    exit 1
fi

# Use git subtree split to create a branch with only CK content at root.
# --rejoin caches the split point so subsequent runs are incremental (fast).
REJOIN_FLAG=()
if [[ "${REJOIN}" == true ]]; then
    REJOIN_FLAG=(--rejoin)
fi

SPLIT_SHA=$(git subtree split --prefix="${CK_PREFIX}" --branch="${SPLIT_BRANCH}" "${REJOIN_FLAG[@]}" "${SOURCE_BRANCH}")

echo ""
echo "==> Done. Branch '${SPLIT_BRANCH}' now at ${SPLIT_SHA}"
echo ""
echo "In your customer repo, you can now do:"
echo "  git remote add rocm-ck /path/to/rocm-libraries"
echo "  git fetch rocm-ck ${SPLIT_BRANCH}"
echo "  # then cherry-pick, merge, or rebase as needed"
echo ""
echo "Or use 'ck-remote-setup' to automate this."
